# ============================================================
# autoflow — Environment Variables (v2.1.0)
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Supabase ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (NEVER expose to client)
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_URL=https://your-project.supabase.co

# ── Authentication ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=autoflow

# ── Google Maps ───────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=AIzaSy_your_key_here

# ── Web Push (VAPID) ──────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ── Sentry (Error Monitoring) ─────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Demo Mode ─────────────────────────────────────────────
# Set to 'false' in production to disable demo login
ENABLE_DEMO_MODE=true

# ── VAPID (Web Push — توليد بـ: npx web-push generate-vapid-keys) ─────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=

# ── SMS Provider ──────────────────────────────────────────────────────────────
SMS_PROVIDER=none        # none | twilio | custom
SMS_API_KEY=             # Twilio: AccountSID:AuthToken | Custom: endpoint URL
SMS_SENDER_ID=autoflow   # Sender name shown on SMS
